rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /items/{itemId} {
      // Semua orang (termasuk yang belum login) bisa membaca laporan
      allow read: if true;

      // Hanya user yang sudah login yang bisa membuat laporan
      allow create: if request.auth != null;

      // Pemilik laporan bisa mengubah semua field dan menghapus laporan
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Update diizinkan untuk pemilik laporan, ATAU untuk pengguna lain jika HANYA mengupdate field klaim
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['claimBy', 'claimCiriCiri', 'claimStatus', 'updatedAt'])
      );
    }
  }
}
